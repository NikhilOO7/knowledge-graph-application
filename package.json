{
  "name": "knowledge-graph-application",
  "private": true,
  "version": "2.0.0",
  "description": "Generic context-bucket knowledge graph system (Python/CrewAI/LangGraph backend + React frontend)",
  "scripts": {
    "infra:up": "docker-compose up -d",
    "infra:down": "docker-compose down",
    "server": "cd apps/server && uvicorn app.main:app --reload --port 3000",
    "server:install": "cd apps/server && pip install -r requirements.txt",
    "web": "pnpm --filter web dev",
    "web:install": "pnpm --filter web install"
  },
  "keywords": ["knowledge-graph", "ai-agents", "crewai", "langgraph", "neo4j", "context-buckets"],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
