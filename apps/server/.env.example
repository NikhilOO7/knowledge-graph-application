# ---- Server ----
PORT=3000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ---- PostgreSQL (documents, buckets, jobs, provenance) ----
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/knowledge_graph

# ---- Neo4j (the knowledge graph itself) ----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# ---- LLM provider: "openai" or "ollama" ----
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (local, used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ---- Context bucket routing ----
# Cosine-similarity threshold above which an uploaded document is appended
# to an existing bucket instead of seeding a new one.
BUCKET_MATCH_THRESHOLD=0.78

# ---- Extraction ----
CHUNK_SIZE=2000
CHUNK_OVERLAP=200
